<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NeZha_Desktop.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <NavigationView x:ConnectionId='2'
        x:Name="AppNavigationView"
        Background="Transparent"
        PaneDisplayMode="Auto"
        IsSettingsVisible="True"
        IsBackButtonVisible="Collapsed"
                                                     
                                                               >
        <NavigationView.MenuItems>
            <NavigationViewItem x:ConnectionId='3'
                x:Name="MonitorRootItem"
                Content="哪吒监控"
                Tag="monitor_root"
                IsExpanded="True"
                SelectsOnInvoked="False">
                <NavigationViewItem.Icon>
                    <BitmapIcon
                        Width="20"
                        Height="20"
                        UriSource="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                        ShowAsMonochrome="False" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:ConnectionId='4' x:Name="UptimeKumaItem" Content="Uptime-Kuma" Tag="uptime_kuma">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="World" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Frame x:ConnectionId='5' x:Name="ContentFrame" Background="Transparent" />
    </NavigationView>
</Page>

