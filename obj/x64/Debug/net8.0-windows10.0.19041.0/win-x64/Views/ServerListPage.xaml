<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NeZha_Desktop.Views.ServerListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="20,16,20,12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="服务器列表" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="{Binding StatusMessage}" Opacity="0.75" />
                <ListView
                    Margin="0,8,0,0"
                    MinHeight="34"
                    MaxHeight="40"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button
                    Width="30"
                    Height="30"
                    Padding="0"
                    Command="{Binding RefreshCommand}"
                    ToolTipService.ToolTip="刷新">
                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="13" Glyph="&#xE777;" />
                </Button>

                <Button x:ConnectionId='4'
                    x:Name="StatusFilterButton"
                    Width="30"
                    Height="30"
                    Padding="0"
                                                      
                    ToolTipService.ToolTip="状态筛选">
                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="13" Glyph="&#xE71C;" />
                </Button>
            </StackPanel>
        </Grid>

        <ListView x:ConnectionId='2'
            x:Name="ServerListControl"
            Grid.Row="1"
            Margin="20,0,20,8"
            Padding="0"
            ItemsSource="{Binding Servers}"
            SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
            IsItemClickEnabled="True"
                                              >
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,12,12"
                        Padding="14"
                        MinWidth="280"
                        MaxWidth="360"
                        MinHeight="190"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Spacing="10">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="●" Foreground="{Binding IsOnline, Converter={StaticResource OnlineStatusBrushConverter}}" />
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" />
                            </Grid>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="系统" Opacity="0.75" />
                                    <TextBlock Text="{Binding System}" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CPU" Opacity="0.75" />
                                    <TextBlock Text="{Binding CpuText}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="内存" Opacity="0.75" />
                                    <TextBlock Text="{Binding MemoryText}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1">
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding CpuPercent}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding MemoryPercent}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="上传" Opacity="0.75" />
                                    <TextBlock Text="{Binding UploadSpeed}" />
                                    <TextBlock Text="{Binding UploadTotal}" FontSize="11" Opacity="0.75" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="下载" Opacity="0.75" />
                                    <TextBlock Text="{Binding DownloadSpeed}" />
                                    <TextBlock Text="{Binding DownloadTotal}" FontSize="11" Opacity="0.75" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                            <Border
                                Grid.Row="1"
                                Margin="-14,8,-14,-14"
                                Padding="10,6"
                                Background="#C62828"
                                CornerRadius="0,0,12,12"
                                Visibility="{Binding IsOnline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        Glyph="&#xE783;"
                                        Foreground="White"
                                        FontSize="12"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Text="服务器已离线"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

