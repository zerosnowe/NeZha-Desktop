<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NeZha_Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NeZha Desktop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:ConnectionId='2'
            x:Name="AppTitleBar"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False"
            Title="NeZha Desktop">
            <TitleBar.LeftHeader>
                <Grid Width="72" Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="24" />
                    </Grid.ColumnDefinitions>

                    <Button x:ConnectionId='4'
                        x:Name="BackButton"
                        Grid.Column="0"
                        Width="32"
                        Height="32"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                                                  
                        ToolTipService.ToolTip="返回">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE72B;" FontSize="14" />
                    </Button>

                    <Image
                        Grid.Column="1"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="ms-appx:///Assets/Square44x44Logo.scale-200.png" />
                </Grid>
            </TitleBar.LeftHeader>

            <TitleBar.Content>
                <AutoSuggestBox x:ConnectionId='5'
                    x:Name="GlobalSearchBox"
                    Width="420"
                    MinWidth="280"
                    MaxWidth="560"
                    Height="32"
                    HorizontalAlignment="Center"
                                                                     
                                                               
                    PlaceholderText="搜索服务器或节点" />
            </TitleBar.Content>
            <TitleBar.RightHeader>
                <Grid Width="72" Height="32" />
            </TitleBar.RightHeader>
        </TitleBar>

        <Frame x:ConnectionId='3'
            x:Name="RootFrame"
            Grid.Row="1" />
    </Grid>
</Window>

