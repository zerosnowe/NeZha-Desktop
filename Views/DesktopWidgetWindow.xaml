<Window
    x:Class="NeZha_Desktop.Views.DesktopWidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        x:Name="RootCard"
        MinWidth="420"
        MinHeight="220"
        Padding="16"
        Background="#33FFFFFF"
        BorderBrush="#40FFFFFF"
        BorderThickness="1"
        CornerRadius="16"
        PointerPressed="RootCard_OnPointerPressed"
        PointerMoved="RootCard_OnPointerMoved"
        PointerReleased="RootCard_OnPointerReleased"
        PointerCanceled="RootCard_OnPointerReleased"
        PointerWheelChanged="RootCard_OnPointerWheelChanged"
        DoubleTapped="RootCard_OnDoubleTapped"
        SizeChanged="RootCard_OnSizeChanged"
        RightTapped="RootCard_OnRightTapped">
        <Grid x:Name="ContentHost" RowSpacing="12" Opacity="1">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ContentTranslateTransform" />
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeaderPanel" Orientation="Horizontal" Spacing="8">
                <Ellipse x:Name="HeaderStatusDot" Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center" />
                <TextBlock x:Name="ServerNameText" FontSize="20" FontWeight="SemiBold" Foreground="#111111" Text="等待服务器列表同步" />
            </StackPanel>

            <Grid
                x:Name="InfoGrid"
                Grid.Row="1"
                ColumnSpacing="8"
                RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <FontIcon x:Name="StatusIcon" Grid.Row="0" Grid.Column="0" FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE7BA;" Foreground="#1A1A1A" />
                <TextBlock x:Name="StatusText" Grid.Row="0" Grid.Column="1" FontSize="16" Foreground="#1A1A1A" Text="状态：--" TextWrapping="WrapWholeWords" />

                <FontIcon x:Name="IpIcon" Grid.Row="1" Grid.Column="0" FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE774;" Foreground="#1A1A1A" />
                <TextBlock x:Name="IpText" Grid.Row="1" Grid.Column="1" FontSize="15" Foreground="#1A1A1A" Text="IP：--" TextWrapping="WrapWholeWords" />

                <FontIcon x:Name="RuntimeIcon" Grid.Row="2" Grid.Column="0" FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE823;" Foreground="#1A1A1A" />
                <TextBlock x:Name="RuntimeText" Grid.Row="2" Grid.Column="1" FontSize="15" Foreground="#1A1A1A" Text="运行时间：--" TextWrapping="WrapWholeWords" />

                <FontIcon x:Name="UsageIcon" Grid.Row="3" Grid.Column="0" FontFamily="Segoe Fluent Icons" FontSize="14" Glyph="&#xE9D9;" Foreground="#1A1A1A" />
                <TextBlock x:Name="UsageText" Grid.Row="3" Grid.Column="1" FontSize="15" Foreground="#1A1A1A" Text="CPU -- / 内存 -- / 磁盘 --" TextWrapping="WrapWholeWords" />
            </Grid>
        </Grid>
    </Border>
</Window>
